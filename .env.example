# Copia este archivo a .env y ajusta los valores
DJANGO_SETTINGS_MODULE=config.settings.development

# true = SQLite sin Docker | false = PostgreSQL (docker compose up -d)
USE_SQLITE=true
DJANGO_SECRET_KEY=cambia-esta-clave-en-produccion
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL — local (Docker) o Supabase (USE_SQLITE=false)
POSTGRES_DB=hospy
POSTGRES_USER=hospy
POSTGRES_PASSWORD=hospy_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# prefer = local sin SSL | require = Supabase (obligatorio en la nube)
POSTGRES_SSLMODE=prefer

# Supabase — conexión DIRECTA (local / IPv6). En Render usar POOLER abajo.
# USE_SQLITE=false
# POSTGRES_HOST=db.qrxochlpoiuftiwwrosi.supabase.co
# POSTGRES_PORT=5432
# POSTGRES_DB=postgres
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=tu-password-de-supabase
# POSTGRES_SSLMODE=require

# Supabase — POOLER (Render, Railway, etc. sin IPv6). Dashboard → Database → Connection pooling → Session
# USE_SQLITE=false
# POSTGRES_HOST=aws-0-sa-east-1.pooler.supabase.com
# POSTGRES_PORT=5432
# POSTGRES_DB=postgres
# POSTGRES_USER=postgres.TU_PROJECT_REF
# POSTGRES_PASSWORD=tu-password-de-supabase
# POSTGRES_SSLMODE=require

# Redis 7
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
# true = ejecutar tareas en el mismo proceso (sin worker)
CELERY_TASK_ALWAYS_EAGER=false

# JWT — sesión hasta cerrar sesión o 30 min sin actividad (renovación en el frontend)
JWT_ACCESS_MINUTES=30
JWT_REFRESH_MINUTES=30

# CORS (frontend u otros clientes)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# Integración SIST / partners
# Preferir clientes registrados en Admin (Integración → Clientes) con API Key por cliente.
# Esta variable queda como fallback legacy/demo.
HOSPY_INTEGRATION_API_KEY=cambia-esta-api-key

# Pagos — mock (curso) | mercadopago | culqi
PAYMENTS_GATEWAY=mock
PAYMENT_EXPIRY_MINUTES=30

# Mercado Pago (recomendado para curso: credenciales TEST sin RUC)
# https://www.mercadopago.com.pe/developers/panel/app
# PAYMENTS_GATEWAY=mercadopago
# MP_ACCESS_TOKEN=TEST-xxxxxxxx
# MP_PUBLIC_KEY=TEST-xxxxxxxx

# Culqi (requiere RUC para afiliación comercio)
# PAYMENTS_GATEWAY=culqi

# ip.guide — geolocalización por IP (auditoría, pagos, Hospix, sugerencias de idioma)
IP_GUIDE_ENABLED=true
IP_GUIDE_API_TEMPLATE=https://ip.guide/{ip}
# IP_GUIDE_API_KEY=
IP_GUIDE_CACHE_SECONDS=86400
IP_GUIDE_TIMEOUT_SECONDS=4
# CULQI_SECRET_KEY=sk_test_...
# CULQI_PUBLIC_KEY=pk_test_...

# Patrocinadores (WhatsApp del admin para acuerdo financiero; código país sin +)
HOSPY_ADMIN_WHATSAPP=51123456789
MAX_SPONSOR_AD_DURATION_SEC=10
MAX_UPLOAD_VIDEO_SIZE_MB=15

# Email (desarrollo: consola)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
FRONTEND_URL=http://localhost:5173

# Google Sign-In (mismo Client ID que VITE_GOOGLE_CLIENT_ID en frontend/.env)
# Crear en https://console.cloud.google.com/apis/credentials — tipo "Aplicación web"
# Orígenes autorizados: http://localhost:5173 y tu dominio de producción
GOOGLE_OAUTH_CLIENT_ID=

# Facebook Login (developers.facebook.com — mismo App ID que VITE_FACEBOOK_APP_ID)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Cloudflare Turnstile (CAPTCHA anti fuerza bruta en login y registro)
# https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Reseñas: true = visibles al enviar; false = moderación admin
REVIEWS_AUTO_APPROVE=true

# Cancelación por huésped: horas mínimas antes del check-in
BOOKING_CANCEL_HOURS_BEFORE_CHECKIN=48

# Auditoría: retención (días activos antes de archivar; días archivados antes de eliminar)
AUDIT_LOG_RETENTION_DAYS=90
AUDIT_LOG_PURGE_ARCHIVED_DAYS=365

# Caché integración SIST (segundos, default 300)
INTEGRATION_CACHE_TIMEOUT=300

# Factiliza — verificación de identidad (DNI / RENIEC) [primario]
# Token Bearer del panel: API Consulta → Token
FACTILIZA_API_TOKEN=
FACTILIZA_BASE_URL=https://api.factiliza.com/v1
# ApiInti — respaldo si Factiliza falla o sin créditos
APIINTI_API_TOKEN=
APIINTI_BASE_URL=https://app.apiinti.dev/api/v1
# true = datos demo sin gastar créditos; false = forzar API real
# (si omites FACTILIZA_MOCK y no hay tokens en DEBUG, usa mock automáticamente)
# FACTILIZA_MOCK=false

# Almacenamiento de archivos (prioridad: Cloudinary > S3/R2 > media/ local)
USE_CLOUDINARY=false
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
USE_S3=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
# Para Cloudflare R2:
# AWS_S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# AWS_S3_CUSTOM_DOMAIN=

# Imágenes
MAX_UPLOAD_IMAGE_SIZE_MB=5
# Calidad WebP al subir (1-100, default 85)
IMAGE_WEBP_QUALITY=85

# Hospix — asistente con IA (Gemini gratuito recomendado)
HOSPIX_LLM_ENABLED=true
HOSPIX_LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
# Memoria temporal del chat (segundos, default 1800 = 30 min). No se guarda en BD.
HOSPIX_SESSION_TTL=1800
HOSPIX_MAX_MESSAGES=40
# GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta

# Alternativa OpenAI (opcional)
# HOSPIX_LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
