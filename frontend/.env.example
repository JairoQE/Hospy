# Copia a .env.local — con proxy de Vite usa ruta relativa
VITE_API_URL=/api/v1

# Minutos sin actividad antes de cerrar sesión (debe coincidir con JWT_ACCESS_MINUTES en .env)
VITE_SESSION_IDLE_MINUTES=30

# Sin proxy (CORS en Django: http://localhost:5173)
# VITE_API_URL=http://127.0.0.1:8000/api/v1

# true = solo motor local (sin llamar a /hospix/chat/)
# VITE_HOSPIX_USE_LOCAL=true

# Tipo de cambio para mostrar precios en USD (soles por 1 dólar)
VITE_PEN_PER_USD=3.75

# Google Sign-In (OAuth 2.0 — ID de cliente web, mismo valor que GOOGLE_OAUTH_CLIENT_ID en .env del backend)
VITE_GOOGLE_CLIENT_ID=

# Facebook Login (App ID público; el secreto solo va en el backend)
VITE_FACEBOOK_APP_ID=

# Cloudflare Turnstile (CAPTCHA login/registro — mismo site key que TURNSTILE_SITE_KEY en backend)
# Crear en https://dash.cloudflare.com/?to=/:account/turnstile
VITE_TURNSTILE_SITE_KEY=

# Banner promocional de app en el home (estilo hero/display ad)
# VITE_APP_PROMO_ENABLED=false
# VITE_APP_PROMO_URL=https://hospy.pe
# VITE_GOOGLE_PLAY_URL=
# VITE_APP_STORE_URL=
