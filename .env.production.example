# Variables para Render (backend) — copia valores reales al panel de Render, NO subas este archivo con secretos.

DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=genera-una-clave-larga-y-aleatoria
DJANGO_ALLOWED_HOSTS=hospy-api.onrender.com

USE_SQLITE=false
POSTGRES_HOST=db.xxxxx.supabase.co
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=tu-password-supabase
POSTGRES_SSLMODE=require

CELERY_TASK_ALWAYS_EAGER=true

CORS_ALLOWED_ORIGINS=https://hospy.pages.dev,https://tu-dominio.com
CSRF_TRUSTED_ORIGINS=https://hospy.pages.dev,https://tu-dominio.com
FRONTEND_URL=https://hospy.pages.dev

USE_CLOUDINARY=true
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

GOOGLE_OAUTH_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
GEMINI_API_KEY=

JWT_ACCESS_MINUTES=30
JWT_REFRESH_MINUTES=30
REVIEWS_AUTO_APPROVE=true
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
