# Variables para Render (backend) — copia valores reales al panel de Render, NO subas este archivo con secretos.

DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=genera-una-clave-larga-y-aleatoria
DJANGO_ALLOWED_HOSTS=hospy-api.onrender.com

USE_SQLITE=false
# Render no alcanza Supabase por IPv6 → usar Connection Pooling (Session), no conexión directa db.*.supabase.co
POSTGRES_HOST=aws-0-sa-east-1.pooler.supabase.com
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres.TU_PROJECT_REF
POSTGRES_PASSWORD=tu-password-supabase
POSTGRES_SSLMODE=require

CELERY_TASK_ALWAYS_EAGER=true
# No configures REDIS_URL ni CELERY_BROKER_URL en Render free (no hay Redis local)

CORS_ALLOWED_ORIGINS=https://hospy.pages.dev,https://tu-dominio.com
CSRF_TRUSTED_ORIGINS=https://hospy.pages.dev,https://tu-dominio.com
FRONTEND_URL=https://hospy.pages.dev

USE_CLOUDINARY=true
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

GOOGLE_OAUTH_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
GEMINI_API_KEY=

JWT_ACCESS_MINUTES=30
JWT_REFRESH_MINUTES=30
REVIEWS_AUTO_APPROVE=true
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Pagos — mock | mercadopago | culqi
PAYMENTS_GATEWAY=mercadopago
MP_ACCESS_TOKEN=TEST-o-APP_USR-tu-access-token
MP_PUBLIC_KEY=TEST-o-APP_USR-tu-public-key
PAYMENT_EXPIRY_MINUTES=30
# Webhook MP (configurar en panel → Notificaciones → Webhooks):
# https://hospy-api.onrender.com/api/v1/pagos/webhook/mercadopago/

## Google Cloud Run (prueba)

1. Instala [Google Cloud SDK](https://cloud.google.com/sdk/docs/install).
2. Crea un proyecto en [Google Cloud Console](https://console.cloud.google.com/) y activa facturación (hay crédito free trial).
3. Copia `.env.gcp.example` → `.env.gcp` y rellena Supabase, Cloudinary, secretos (mismos que Render).
4. En PowerShell:

```powershell
gcloud auth login
gcloud auth application-default login
cd deploy/gcp
.\deploy.ps1
```

5. Anota la URL (`https://hospy-api-xxxxx.run.app`) y configura el frontend:

```env
VITE_API_URL=https://hospy-api-xxxxx.run.app/api/v1
```

6. Añade la URL del frontend en `CORS_ALLOWED_ORIGINS` y `CSRF_TRUSTED_ORIGINS` en `.env.gcp` y vuelve a ejecutar `deploy.ps1`.

**Notas:** `min-instances=1` evita cold start (~USD 5–15/m según región). Región recomendada: `southamerica-east1` (São Paulo). Ver `cloudbuild.yaml` para CI/CD.
