# Copia este archivo como .env.production.local (en la raíz del proyecto)
# y rellena con los valores del panel de Render → hospy-api → Environment.
# NO subas .env.production.local a Git (ya está en .gitignore).

DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=pega-aqui-el-valor-de-render

USE_SQLITE=false
POSTGRES_HOST=aws-0-sa-east-1.pooler.supabase.com
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres.TU_PROJECT_REF
POSTGRES_PASSWORD=tu-password-supabase
POSTGRES_SSLMODE=require
