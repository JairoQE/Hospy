# Copia a .env.gcp y rellena valores reales (NO subir a Git).
# Usado por deploy/gcp/deploy.ps1 para Cloud Run.

GCP_PROJECT_ID=tu-proyecto-gcp
GCP_REGION=southamerica-east1
GCP_SERVICE_NAME=hospy-api

# Django
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=genera-una-clave-larga-y-aleatoria
# Tras el primer deploy puedes añadir la URL exacta; .run.app se acepta solo en Cloud Run
DJANGO_ALLOWED_HOSTS=.run.app

USE_SQLITE=false
POSTGRES_HOST=aws-0-sa-east-1.pooler.supabase.com
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres.TU_PROJECT_REF
POSTGRES_PASSWORD=tu-password-supabase
POSTGRES_SSLMODE=require

CELERY_TASK_ALWAYS_EAGER=true
# Opcional (recomendado): Upstash Redis free → REDIS_URL=rediss://...

CORS_ALLOWED_ORIGINS=https://hospy.pages.dev,https://tu-frontend.com
CSRF_TRUSTED_ORIGINS=https://hospy.pages.dev,https://tu-frontend.com
FRONTEND_URL=https://hospy.pages.dev

USE_CLOUDINARY=true
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

GOOGLE_OAUTH_CLIENT_ID=
GEMINI_API_KEY=
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

PAYMENTS_GATEWAY=mercadopago
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
PAYMENT_EXPIRY_MINUTES=30

# Verificación de identidad (Factiliza primario → ApiInti respaldo). NO subir tokens a Git.
FACTILIZA_API_TOKEN=
FACTILIZA_BASE_URL=https://api.factiliza.com/v1
APIINTI_API_TOKEN=
APIINTI_BASE_URL=https://app.apiinti.dev/api/v1
FACTILIZA_MOCK=false

# Actify — eventos externos. NO subir la key a Git.
ACTIFY_API_KEY=
ACTIFY_BASE_URL=https://actify.qd.je/api/v1

# Conecta Tingo — hotspots / demanda. NO subir la key a Git.
CONECTA_TINGO_API_KEY=
CONECTA_TINGO_BASE_URL=https://conectatingo.com/api/integracion

# RestoPoint — restaurantes. NO subir la key a Git.
RESTOPOINT_API_KEY=
RESTOPOINT_BASE_URL=https://restaurants-backend-ni6d.onrender.com/api/v1/developer-api
